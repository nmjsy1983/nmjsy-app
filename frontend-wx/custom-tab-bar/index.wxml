<cover-view class="tab-bar">
  <cover-view class="tab-bar-border"></cover-view>
  <cover-view class="tab-bar-item" wx:for="{{list}}" wx:key="index" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <cover-image class="tab-bar-icon {{selected === index ? 'active' : ''}}" src="{{selected === index ? item.selectedIconPath : item.iconPath}}"></cover-image>
    <cover-view class="tab-bar-text {{selected === index ? 'active' : ''}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
