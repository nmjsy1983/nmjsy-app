<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view class="tab-bar-item {{selected === index ? 'active' : ''}}" wx:for="{{list}}" wx:key="index" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-bar-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}"></image>
    <view class="tab-bar-text">{{item.text}}</view>
  </view>
</view>
