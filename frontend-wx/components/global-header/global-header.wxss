.global-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg);
  border-bottom: 1rpx solid var(--border);
}

.header-inner {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.brand-mark {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.brand-icon {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.brand-name {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
  width: 4.1em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.header-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ea580c, #fb923c);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
