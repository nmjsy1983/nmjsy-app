.record-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.record-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 24rpx 0;
  background: var(--card);
  border-radius: var(--radius);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
}

.record-item:active {
  transform: scale(0.96);
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.record-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.recent-card .card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.card-more {
  font-size: 24rpx;
  color: var(--text-muted);
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.recent-info {
  flex: 1;
  min-width: 0;
}

.recent-desc {
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.recent-time {
  font-size: 24rpx;
  color: var(--text-muted);
}
