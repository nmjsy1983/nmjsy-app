<view class="container">
  <global-header title="审批中心" />

  <view class="page-content">
    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === item.key ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onTabTap"
      >
        {{item.name}}
        <text wx:if="{{item.count > 0}}" class="tab-badge">{{item.count}}</text>
      </view>
    </view>

    <view 
      class="card approval-item"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onItemTap"
    >
      <view class="approval-title">{{item.title}}</view>
      <view class="approval-meta">
        <text>申请人：{{item.applicant}}</text>
        <text>{{item.time}}</text>
      </view>
      <view class="approval-footer" wx:if="{{item.amount}}">
        <view class="approval-amount">{{item.amount}}</view>
        <view class="approval-status">待审批</view>
      </view>
    </view>
  </view>
</view>
