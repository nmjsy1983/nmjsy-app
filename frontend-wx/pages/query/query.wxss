.search-bar {
  margin-bottom: 32rpx;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 28rpx;
  background: var(--card);
  border-radius: var(--radius);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-muted);
}

.query-group {
  margin-bottom: 32rpx;
}

.query-group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.query-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 28rpx 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
}

.query-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
}

.query-item:active {
  transform: scale(0.96);
}

.query-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.query-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}
