<view class="container">
  <global-header title="数据中心" />

  <view class="page-content">
    <view class="summary-cards">
      <view class="summary-card">
        <view class="summary-value">128</view>
        <view class="summary-label">总工日</view>
      </view>
      <view class="summary-card">
        <view class="summary-value">¥8.5w</view>
        <view class="summary-label">本月支出</view>
      </view>
    </view>

    <view class="card data-grid">
      <view class="data-grid-title">数据看板</view>
      <view class="data-grid-items">
        <view 
          class="data-grid-item"
          wx:for="{{modules}}"
          wx:key="name"
          data-name="{{item.name}}"
          bindtap="onModuleTap"
        >
          <view class="data-grid-icon" style="background: {{item.bg}}; color: {{item.color}};">{{item.icon}}</view>
          <view class="data-grid-name">{{item.name}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
