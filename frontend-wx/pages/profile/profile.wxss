.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: var(--radius);
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #fed7aa;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.user-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.menu-group {
  margin-bottom: 24rpx;
}

.menu-group-title {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-card {
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.menu-title {
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.logout-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #fff;
  color: var(--red);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 500;
}

.logout-btn::after {
  border: none;
}
